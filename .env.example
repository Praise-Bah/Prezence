# Prezence — Environment Variable Template
# Copy to .env for local overrides if needed. Real values live in Doppler.
# Never commit a populated .env file.

# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis / Upstash ────────────────────────────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ─── OpenRouter (AI) ────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Payments ───────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_MASTER_KEY=

# ─── Monitoring (Sentry) ────────────────────────────────────
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# ─── Integrations ───────────────────────────────────────────
GITHUB_TOKEN=
FIGMA_ACCESS_TOKEN=

# ─── Automation ─────────────────────────────────────────────
SMARTPROXY_USERNAME=
SMARTPROXY_PASSWORD=

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
