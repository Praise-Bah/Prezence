# Prezence — Environment Variable Template
# Copy to .env for local overrides if needed. Real values live in Doppler.
# Never commit a populated .env file.

# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database (direct Postgres connection for TypeORM) ──────
# Supabase project settings → Database → Connection string (use the
# pooler/transaction-mode URI). NestJS connects directly, bypassing RLS.
DATABASE_URL=

# ─── Redis (Upstash) ────────────────────────────────────────
REDIS_URL=
REDIS_TOKEN=

# ─── AI ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Payment — MVP (Screenshot Verification) ─────────────────
# Users pay directly to these numbers via MTN MoMo or Orange Money
# then upload a screenshot. AI screens it. Founder confirms manually.
FOUNDER_MTN_NUMBER=
FOUNDER_ORANGE_NUMBER=
SCREENSHOT_AI_MODEL=anthropic/claude-sonnet-4.6
SCREENSHOT_CONFIDENCE_THRESHOLD_HIGH=80
SCREENSHOT_CONFIDENCE_THRESHOLD_MEDIUM=60
SCREENSHOT_MAX_UPLOADS_PER_DAY=3
PROVISIONAL_ACCESS_HOURS=24

# ─── Payment — Phase 2 (add when Flutterwave account approved) ───
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_HASH=

# ─── Payment — Phase 2 (Nigeria/Ghana via Paystack) ──────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Monitoring ───────────────────────────────────────────────
SENTRY_AUTH_TOKEN=
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_ORG=prezence

# ─── Storage (Cloudflare R2) ────────────────────────────────
# R2 is S3-compatible. Bucket → Settings → R2.dev subdomain = R2_PUBLIC_URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=prezence-media
R2_PUBLIC_URL=

# ─── Notifications (Resend) ─────────────────────────────────
# Optional — if not set, email sending is skipped gracefully (logged as warning)
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=Prezence <noreply@prezence.app>

# ─── Integrations ───────────────────────────────────────────
GITHUB_TOKEN=
FIGMA_ACCESS_TOKEN=

# ─── Platform OAuth (LinkedIn + Meta) ───────────────────────
# LinkedIn: https://developer.linkedin.com → Create App → Auth
# Redirect URI to register: {API_URL}/integration/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta: https://developers.facebook.com → Create App → Facebook Login
# Redirect URI to register: {API_URL}/integration/oauth/facebook/callback
META_APP_ID=
META_APP_SECRET=

# Public-facing URL of the Next.js frontend (used for OAuth post-connect redirect)
FRONTEND_URL=http://localhost:3000

# ─── Token Vault (AES-256-GCM for platform OAuth tokens) ────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Automation / L3A Playwright (Smartproxy) ────────────────
# Optional — only needed when L3A browser automation is active
SMARTPROXY_HOST=
SMARTPROXY_USERNAME=
SMARTPROXY_PASSWORD=

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001          # NestJS API port — web (Next.js) runs on 3000 by default

# ─── Web (Next.js) ────────────────────────────────────────────
# Server-only URL for SSR/Server Actions — NOT prefixed with NEXT_PUBLIC_
# so the internal address is never inlined into the client JS bundle.
API_URL=http://localhost:3001

# WebSocket server URL (public — inlined into client bundle)
# In production: wss://api.prezence.app (same host as NestJS API)
NEXT_PUBLIC_WS_URL=http://localhost:3001
