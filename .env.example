# Prezence — Environment Variable Template
# Copy to .env for local overrides if needed. Real values live in Doppler.
# Never commit a populated .env file.

# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis (Upstash) ────────────────────────────────────────
REDIS_URL=
REDIS_TOKEN=

# ─── AI ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Payment — MVP (Screenshot Verification) ─────────────────
# Users pay directly to these numbers via MTN MoMo or Orange Money
# then upload a screenshot. AI screens it. Founder confirms manually.
FOUNDER_MTN_NUMBER=
FOUNDER_ORANGE_NUMBER=
SCREENSHOT_AI_MODEL=anthropic/claude-sonnet-4.6
SCREENSHOT_CONFIDENCE_THRESHOLD_HIGH=80
SCREENSHOT_CONFIDENCE_THRESHOLD_MEDIUM=60
SCREENSHOT_MAX_UPLOADS_PER_DAY=3
PROVISIONAL_ACCESS_HOURS=24

# ─── Payment — Phase 2 (add when Flutterwave account approved) ───
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_HASH=

# ─── Payment — Phase 2 (Nigeria/Ghana via Paystack) ──────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_MASTER_KEY=

# ─── Monitoring ───────────────────────────────────────────────
SENTRY_AUTH_TOKEN=
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_ORG=prezence

# ─── Storage ────────────────────────────────────────────────
# Cloudflare R2 — for payment screenshots, profile images, proof files
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=prezence-media

# ─── Integrations ───────────────────────────────────────────
GITHUB_TOKEN=
FIGMA_ACCESS_TOKEN=

# ─── Automation ─────────────────────────────────────────────
SMARTPROXY_USERNAME=
SMARTPROXY_PASSWORD=

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
